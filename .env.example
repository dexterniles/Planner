# =============================================================================
# Planner — environment variable template
# =============================================================================
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored; this file is committed as documentation.
#
# For each variable, the comment above it says where to get the value.
# =============================================================================


# ----- Supabase ---------------------------------------------------------------
# Get from: Supabase Dashboard → your project → Settings → API
# This is the public REST/auth endpoint. Safe to expose in client bundles.
NEXT_PUBLIC_SUPABASE_URL=""

# Get from: Supabase Dashboard → Settings → API → API keys
# Label varies: "anon public" (legacy) or "publishable" (new). Both work with
# `@supabase/supabase-js@^2.45`. Safe to expose in client bundles.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Get from: Supabase Dashboard → Settings → API → API keys
# Label varies: "service_role" (legacy) or "secret" (new). FULL ADMIN ACCESS.
# Used server-side only (e.g. lib/supabase/server.ts). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=""

# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
# Toggle "Use connection pooler" ON, mode = Transaction, port 6543. This is the
# right URL for serverless runtime (Vercel) — drizzle's runtime client uses it.
# Format: postgresql://postgres.PROJECTREF:PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=""


# ----- App security -----------------------------------------------------------
# The app uses this as a single-user email allowlist. It is fail-closed —
# the app refuses to boot if this is unset or empty (see proxy.ts, lib/auth).
# Set this to YOUR Supabase auth email. Must match exactly (case-insensitive).
ALLOWED_ADMIN_EMAIL=""

# Bearer token for /api/cron/auto-complete. Vercel cron sends
# Authorization: Bearer ${CRON_SECRET}. Generate with: openssl rand -base64 32
# (or any long random string).
CRON_SECRET=""


# ----- Seed scripts (one-time, optional) --------------------------------------
# Used by `npm run db:seed` to create starter workspaces for your user.
# After your first sign-in to the deployed app, look up your Supabase auth UUID:
#   Supabase Dashboard → Authentication → Users → your row → "User UID" column
# Paste that UUID here, then run `npm run db:seed` once.
SEED_USER_ID=""
